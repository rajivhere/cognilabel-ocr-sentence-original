# --- data (matches your current mount: D:\User\dataset -> /data/dataset)
CL_JSONL_LOCAL=/data/dataset/train/annotations/labels.jsonl
CL_JSONL_LOCAL_VAL=/data/dataset/val/annotations/labels.jsonl
CL_JSONL_LOCAL_TEST=/data/dataset/test/annotations/labels.jsonl

CL_IMAGE_BASE=/data
CL_IMAGE_BASE_VAL=/data
CL_IMAGE_BASE_TEST=/data

# --- outputs/cache
CL_OUTPUT=/app/outputs
CL_CACHE_DIR=/app/cache_run1

# --- core hypers (override anything you want)
HYPERPARAMS_JSON={"arch":"resnet_lstm","width":1048,"height":96,"batch_size":8,"epochs":3}


# --- patience/checkpoints (optional) ---
CGL_EARLYSTOP_PATIENCE=3
# CGL_SAVE_EVERY_N_EPOCHS=1

# --- threading (leave unset to auto-tune) ---
# CGL_TF_INTRA_OP=4
# CGL_TF_INTER_OP=4